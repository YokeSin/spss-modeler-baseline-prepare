{
  "mcpServers": {
    "spss-clemb-mcp": {
      "command": "python",
      "args": ["-m", "spss_clemb_mcp.server"],
      "cwd": "<path-to-spss-clemb-mcp>",
      "alwaysAllow": [
        "execute_clemb"
      ]
    },
    "ibm-docs": {
      "command": "python",
      "args": ["-m", "ibm_docs.server"],
      "cwd": "<path-to-ibm-docs-mcp>",
      "alwaysAllow": [
        "search_ibm_docs",
        "get_ibm_topic"
      ]
    }
  }
}
